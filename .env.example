# External API keys — server-side only. Copy to .env.local and fill in.
# These are read in Next.js route handlers and never exposed to the browser.

# World Labs Marble — https://platform.worldlabs.ai
WORLD_LABS_API_KEY=

# Meshy AI (image-to-3D) — https://www.meshy.ai  (key format: msy-...)
MESHY_API_KEY=
