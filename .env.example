# Environment — copy to .env.local and fill in. Server-side only; never exposed
# to the browser.

# --- External generation APIs ---
# World Labs Marble — https://platform.worldlabs.ai
WORLD_LABS_API_KEY=

# Meshy AI (image-to-3D) — https://www.meshy.ai  (key format: msy-...)
MESHY_API_KEY=

# --- Cloud persistence (Neon + Vercel Blob + better-auth) ---
# Neon Postgres pooled connection string — https://neon.tech (or Vercel ▸ Storage)
DATABASE_URL=

# Vercel Blob read/write token — auto-injected on Vercel; needed locally for
# uploads + the demo seed.  Vercel ▸ Storage ▸ Blob ▸ .env.local
BLOB_READ_WRITE_TOKEN=

# better-auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of the app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000
